generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(USER)
  avatarUrl          String?
  headline           String?
  location           String?
  isActive           Boolean             @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  firstName          String
  lastName           String
  username           String              @unique
  aiFeedbacks        AiFeedback[]
  analyticsEvents    AnalyticsEvent[]
  careerRoadmaps     CareerRoadmap[]
  chatbotSessions    ChatbotSession[]
  interviewSessions  InterviewSession[]
  jobRecommendations JobRecommendation[]
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  resumes            Resume[]

  @@index([role, isActive])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model Resume {
  id          String           @id @default(cuid())
  userId      String
  title       String
  fileUrl     String
  fileType    String
  fileSize    Int?
  status      ProcessingStatus @default(PENDING)
  parsedText  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  aiFeedbacks AiFeedback[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([deletedAt])
  @@map("resumes")
}

model InterviewSession {
  id          String          @id @default(cuid())
  userId      String
  title       String
  roleTarget  String
  level       String?
  status      InterviewStatus @default(SCHEDULED)
  questions   Json?
  transcript  Json?
  score       Float?
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  aiFeedbacks AiFeedback[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledAt])
  @@index([roleTarget])
  @@index([deletedAt])
  @@map("interview_sessions")
}

model AiFeedback {
  id                 String            @id @default(cuid())
  userId             String
  resumeId           String?
  interviewSessionId String?
  careerRoadmapId    String?
  chatbotSessionId   String?
  type               AiFeedbackType
  provider           AiProvider
  status             ProcessingStatus  @default(COMPLETED)
  score              Float?
  summary            String?
  strengths          Json?
  weaknesses         Json?
  suggestions        Json?
  promptTokens       Int?
  completionTokens   Int?
  rawResponse        Json?
  errorMessage       String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  careerRoadmap      CareerRoadmap?    @relation(fields: [careerRoadmapId], references: [id], onDelete: Cascade)
  chatbotSession     ChatbotSession?   @relation(fields: [chatbotSessionId], references: [id], onDelete: Cascade)
  interviewSession   InterviewSession? @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  resume             Resume?           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([resumeId])
  @@index([interviewSessionId])
  @@index([careerRoadmapId])
  @@index([chatbotSessionId])
  @@index([provider, status])
  @@map("ai_feedbacks")
}

model CareerRoadmap {
  id           String           @id @default(cuid())
  userId       String
  targetRole   String
  currentLevel String
  status       ProcessingStatus @default(PENDING)
  milestones   Json
  skills       Json?
  timeline     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  aiFeedbacks  AiFeedback[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([targetRole])
  @@index([deletedAt])
  @@map("career_roadmaps")
}

model ChatbotSession {
  id            String           @id @default(cuid())
  userId        String
  title         String?
  context       Json?
  messages      Json
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  aiFeedbacks   AiFeedback[]
  messageList   ChatbotMessage[]
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastMessageAt])
  @@index([deletedAt])
  @@map("chatbot_sessions")
}

model ChatbotMessage {
  id        String         @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime       @default(now())
  session   ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chatbot_messages")
}

model JobRecommendation {
  id          String    @id @default(cuid())
  userId      String
  source      String
  externalId  String?
  title       String
  company     String
  location    String?
  jobUrl      String?
  matchScore  Float
  skillsMatch Json?
  metadata    Json?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([userId, matchScore])
  @@index([company])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("job_recommendations")
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status, createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  userId     String?
  eventType  AnalyticsEventType
  eventName  String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime           @default(now())
  user       User?              @relation(fields: [userId], references: [id])

  @@index([eventType, createdAt])
  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("analytics_events")
}

enum UserRole {
  USER
  ADMIN
  MENTOR
}

enum AiProvider {
  OPENAI
  GEMINI
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum InterviewStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  SYSTEM
  EMAIL
  IN_APP
  REMINDER
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum AiFeedbackType {
  RESUME_ANALYSIS
  INTERVIEW_FEEDBACK
  ROADMAP_GENERATION
  CHATBOT_RESPONSE
  JOB_RECOMMENDATION
}

enum AnalyticsEventType {
  AUTH
  RESUME
  INTERVIEW
  ROADMAP
  CHATBOT
  JOB
  NOTIFICATION
  ADMIN
  SYSTEM
}
