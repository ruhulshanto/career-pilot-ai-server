# Career Pilot AI backend environment
# Copy this file to .env for local development. Never commit real secrets.

# Runtime
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=1mb
DEMO_LOGIN_ENABLED=true

# Database
DATABASE_URL="postgresql://career_pilot:career_pilot_password@localhost:5432/career_pilot?schema=public"
PRISMA_CONNECT_RETRIES=3
PRISMA_CONNECT_RETRY_DELAY_MS=5000
PRISMA_TRANSACTION_MAX_WAIT_MS=20000
PRISMA_TRANSACTION_TIMEOUT_MS=60000
PRISMA_KEEP_ALIVE_INTERVAL_MS=60000

# Redis / queues
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_with_a_32_plus_character_access_secret
JWT_REFRESH_SECRET=replace_with_a_different_32_plus_character_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Optional. Leave blank for localhost or single-domain API cookies.
COOKIE_DOMAIN=

# Email - Gmail SMTP for development/portfolio deployment
EMAIL_PROVIDER=gmail
EMAIL_FROM="Career Pilot AI <your.gmail.address@gmail.com>"
EMAIL_REPLY_TO=your.gmail.address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.gmail.address@gmail.com
SMTP_PASS=replace_with_google_app_password

# AI
AI_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=replace_with_groq_api_key
CHATBOT_GROQ_MODEL=llama-3.1-8b-instant
CHATBOT_GROQ_API_KEY=replace_with_chatbot_groq_api_key
